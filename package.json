{
  "name": "ghc-proxy",
  "type": "module",
  "version": "0.2.0",
  "description": "GitHub Copilot to OpenAI/Anthropic API proxy - Use Copilot with Claude Code, Cursor, and more",
  "author": "wxxb789 <wxxb789@outlook.com>",
  "homepage": "https://github.com/wxxb789/ghc-proxy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wxxb789/ghc-proxy.git"
  },
  "bugs": "https://github.com/wxxb789/ghc-proxy/issues",
  "keywords": [
    "proxy",
    "github-copilot",
    "openai-compatible"
  ],
  "bin": {
    "ghc-proxy": "./dist/main.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "bun run --watch ./src/main.ts",
    "knip": "knip-bun",
    "lint": "eslint --cache",
    "lint:all": "eslint --cache .",
    "prepack": "bun run build",
    "prepare": "simple-git-hooks",
    "release": "bun run release:patch",
    "release:patch": "bumpp patch --yes --commit --tag",
    "release:minor": "bumpp minor --yes --commit --tag",
    "release:major": "bumpp major --yes --commit --tag",
    "matrix:live": "bun run scripts/live-compat-matrix.ts",
    "smoke:packaged": "bun run scripts/packaged-smoke-test.ts",
    "start": "NODE_ENV=production bun run ./src/main.ts",
    "typecheck": "npx tsc --project tsconfig.json"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "citty": "^0.2.1",
    "clipboardy": "^5.3.1",
    "consola": "^3.4.2",
    "elysia": "^1.4.27",
    "fetch-event-stream": "^0.1.6",
    "gpt-tokenizer": "^3.4.0",
    "proxy-from-env": "^2.0.0",
    "srvx": "^0.11.8",
    "tiny-invariant": "^1.3.3",
    "undici": "^7.22.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "@types/bun": "^1.3.10",
    "@types/proxy-from-env": "^1.0.4",
    "bumpp": "^10.4.1",
    "eslint": "^10.0.2",
    "knip": "^5.85.0",
    "lint-staged": "^16.3.1",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged"
  },
  "lint-staged": {
    "*": "bun run lint --fix"
  }
}
